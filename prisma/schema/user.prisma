model User {
    id         String     @id @default(uuid())
    name       String
    email      String     @unique
    phone      String?    @unique
    password   String
    address    String?
    city       String?
    country    String?
    role       Role       @default(Customer)
    status     Status     @default(ACTIVE)
    categoryId Category[]
    gearItemId GearItem[]
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt
}
